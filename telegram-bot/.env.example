# ── Required ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Public HTTPS URL where the mini app is served (from Vite build).
# Must be registered with @BotFather: /newapp → pick your bot → paste this URL.
# Example: https://voiceclaw-tg.pages.dev
MINIAPP_URL=

# ── Optional ─────────────────────────────────────────────────────────────────

# Path to the SQLite store that holds per-user relay URLs.
# Default: ./data/bot.db
# BOT_DB_PATH=./data/bot.db
