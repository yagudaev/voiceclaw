# Desktop build-time credentials for local signed + notarized DMG builds.
#
# Copy to `.env.build` (which is gitignored) and fill in the real values
# from the locations noted in `desktop/build/README.md`. The `dist:mac`
# script sources this file before invoking electron-builder.
#
# Do NOT commit a populated `.env.build`.

# Path to the App Store Connect API key file (the .p8 downloaded from
# appstoreconnect.apple.com/access/integrations/api). The file itself
# lives outside the repo. Typical path on macOS:
# APPLE_API_KEY=~/.appstore/AuthKey_XXXXXXXXXX.p8
APPLE_API_KEY=~/.appstore/AuthKey_XXXXXXXXXX.p8

# Key ID — shown next to the key on the API Keys page. Matches the
# "XXXXXXXXXX" in the filename above.
APPLE_API_KEY_ID=XXXXXXXXXX

# Issuer ID — the UUID shown above the key list on the same page.
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
