# Desktop build-time credentials for local signed + notarized DMG builds.
#
# Copy to `.env.build` (which is gitignored) and keep it alongside the
# desktop package. The `dist:mac` script sources this file before
# invoking electron-builder.
#
# Do NOT commit a populated `.env.build`. The .p8 path below points
# outside the repo intentionally.

# Path to the App Store Connect API key file (the .p8 downloaded from
# appstoreconnect.apple.com/access/integrations/api). Shared with the
# mobile release pipeline per mobile/CLAUDE.md.
APPLE_API_KEY=~/.appstore/AuthKey_SG645CPQP8.p8

# Key ID — shown next to the key on the API Keys page. Matches the
# filename suffix above.
APPLE_API_KEY_ID=SG645CPQP8

# Issuer ID — the UUID shown above the key list on the same page.
# Unique per Apple Developer team; not secret on its own, but the
# combination of ISSUER + KEY_ID + .p8 is what grants access.
APPLE_API_ISSUER=69a6de83-015f-47e3-e053-5b8c7c11a4d1
