# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key for Realtime API access
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Gemini API key for Gemini Live access
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# API key clients must send to connect to this relay server
# Generate one: openssl rand -hex 24
RELAY_API_KEY=

# Brain agent gateway auth token (formerly OPENCLAW_GATEWAY_AUTH_TOKEN)
# If using OpenClaw, found in ~/.openclaw/openclaw.json under gateway.auth.token
BRAIN_GATEWAY_AUTH_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────────

# Server port (default: 8080)
# PORT=8080

# Brain agent gateway URL -- any OpenAI-compatible endpoint (formerly OPENCLAW_GATEWAY_URL)
# BRAIN_GATEWAY_URL=http://localhost:18789

# Brain agent workspace path (used in system instructions; formerly OPENCLAW_WORKSPACE)
# BRAIN_WORKSPACE=

# OpenAI session rotation interval in ms (default: 50 minutes)
# ROTATION_INTERVAL_MS=3000000

# Langfuse tracing (optional — relay runs fine without these)
# Cloud: https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US)
# Self-hosted: point at your own deployment
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# Dual-export OTel spans to a local tracing-ui collector alongside Langfuse.
# When set, the relay posts OTLP-HTTP to this URL in addition to Langfuse.
# TRACING_UI_COLLECTOR_URL=http://127.0.0.1:4318/v1/traces
