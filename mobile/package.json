{
  "name": "voiceclaw-mobile",
  "main": "expo-router/entry",
  "version": "1.4.0",
  "scripts": {
    "dev": "expo start -c",
    "run:ios": "APP_VARIANT=development expo run:ios",
    "run:ios:device": "APP_VARIANT=development expo run:ios --device",
    "run:ios:release": "APP_VARIANT=development expo run:ios --device --configuration Release",
    "prebuild:ios": "APP_VARIANT=development npx expo prebuild --clean",
    "build:ios:staging": "APP_VARIANT=staging ./scripts/build-ios.sh",
    "build:ios:production": "APP_VARIANT=production ./scripts/build-ios.sh",
    "submit:ios:staging": "eas submit --profile staging --platform ios --path build/export/*.ipa",
    "submit:ios:production": "eas submit --profile production --platform ios --path build/export/*.ipa",
    "release:ios:staging": "./scripts/release-to-testflight.sh staging",
    "release:ios:production": "./scripts/release-to-testflight.sh production",
    "clean": "rm -rf .expo node_modules ios android"
  },
  "dependencies": {
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/native": "^7.1.33",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/portal": "~1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~56.0.11",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.10",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "lucide-react-native": "^1.11.0",
    "nativewind": "^4.2.3",
    "posthog-react-native": "^4.43.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.10",
    "canvas": "^3.2.3",
    "expo-mcp": "~0.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
