{
  "name": "@voiceclaw/openclaw-plugin",
  "version": "0.1.0",
  "description": "OpenClaw plugin for VoiceClaw using the native OpenClaw Plugin SDK",
  "type": "module",
  "private": true,
  "packageManager": "yarn@4.9.2",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "openclaw": "^2026.4.24"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "resolutions": {
    "hono": "^4.12.14",
    "fast-xml-parser": "^5.7.0"
  },
  "keywords": [
    "openclaw",
    "voiceclaw",
    "plugin",
    "sdk",
    "agent"
  ],
  "license": "MIT"
}
