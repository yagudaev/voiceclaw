{
  "name": "voiceclaw",
  "private": true,
  "workspaces": [
    "mobile",
    "website",
    "relay-server",
    "desktop",
    "docs"
  ],
  "scripts": {
    "dev": "concurrently --names mobile,web,server \"yarn dev:mobile\" \"yarn dev:web\" \"yarn dev:server\"",
    "dev:server": "cd relay-server && yarn dev 2>&1 | tee ../logs/relay.log",
    "dev:mobile": "cd mobile && yarn dev 2>&1 | tee ../logs/mobile.log",
    "dev:web": "cd website && yarn dev",
    "build:web": "cd website && yarn build",
    "start:web": "cd website && yarn start",
    "lint:web": "cd website && yarn lint",
    "run:ios": "cd mobile && yarn run:ios",
    "run:ios:device": "cd mobile && yarn run:ios:device",
    "run:ios:release": "cd mobile && yarn run:ios:release",
    "prebuild:ios": "cd mobile && yarn prebuild:ios",
    "build:ios:staging": "cd mobile && yarn build:ios:staging",
    "build:ios:production": "cd mobile && yarn build:ios:production",
    "submit:ios:staging": "cd mobile && yarn submit:ios:staging",
    "submit:ios:production": "cd mobile && yarn submit:ios:production",
    "release:ios:staging": "cd mobile && yarn release:ios:staging",
    "release:ios:production": "cd mobile && yarn release:ios:production",
    "deploy:ios:staging": "cd mobile && yarn deploy:ios:staging",
    "deploy:ios:production": "cd mobile && yarn deploy:ios:production",
    "clean:mobile": "cd mobile && yarn clean",
    "dev:desktop": "cd desktop && yarn dev",
    "dev:docs": "cd docs && yarn dev",
    "build:docs": "cd docs && yarn build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3"
  }
}
